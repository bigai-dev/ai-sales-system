# Turso (libSQL) database — `turso db create salesai-dev` then `turso db tokens create salesai-dev`
TURSO_DATABASE_URL=libsql://<your-db>.turso.io
TURSO_AUTH_TOKEN=

# DeepSeek API (https://platform.deepseek.com → Account → API Keys)
DEEPSEEK_API_KEY=

# Cron auth for /api/cron/grade-calls. Vercel auto-injects this as a Bearer
# token on scheduled invocations. Pick a long random string (>=32 chars).
# Without this set, the cron endpoint will reject all requests in production.
CRON_SECRET=
